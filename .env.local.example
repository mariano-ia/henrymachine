# Copiá este archivo a .env.local y completá los valores.

# --- Dominio (prod). Sin esto, el SEO/OG/emails caen al fallback del código. ---
NEXT_PUBLIC_SITE_URL=https://caminaconhenry.com

# --- Gemini (Google AI Studio): https://aistudio.google.com/app/apikey ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# failover automático cuando la key primaria agota crédito/cuota
GEMINI_API_KEY_FALLBACK=

# --- Controles de lanzamiento (opcionales) ---
# CHAT_DISABLED=1  → apaga el chat sin deploy (botón de pánico)
CHAT_DISABLED=
# tope GLOBAL de turnos de LLM por día (backstop de costo). Vacío = sin tope.
DAILY_TURN_BUDGET=

# --- Email (Resend). Sin key, no se manda nada (no rompe la compra). ---
RESEND_API_KEY=
# override del remitente cuando caminaconhenry.com esté verificado en Resend
EMAIL_FROM=

# --- Google Places (horarios reales de la parada; opcional) ---
GOOGLE_MAPS_API_KEY=

# --- Supabase (proyecto henry-machine) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role: dashboard → Project Settings → API (secreto, solo server)
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (más adelante) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
